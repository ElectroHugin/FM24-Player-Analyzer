# ============================================
# Legacy Python/Streamlit app (legacy/)
# ============================================
__pycache__/
*.py[cod]
*$py.class

# Personal player data — never commit
legacy/databases/*.db
legacy/backups/

# User config and assets
legacy/config/config*
legacy/config/assets/logo.png
legacy/config/assets/flag.png

# Streamlit local files
legacy/.streamlit/secrets.toml
legacy/.streamlit/config.toml

# Launcher runtime files
legacy/launcher.log
legacy/.streamlit_server.pid
legacy/*.bat

# Virtual environments
venv/
.venv/
env/
.env/

# ============================================
# C++/Qt app (desktop/)
# ============================================
desktop/build*/
desktop/installer/Output/
desktop/installer/output/
desktop/installer/staging/
desktop/translations/*.qm
desktop/src/tests/golden/local/
CMakeUserPresets.json
CMakeLists.txt.user*

# ============================================
# IDE / misc
# ============================================
.idea/
.vscode/
aqtinstall.log
*.log
.qtcreator/
